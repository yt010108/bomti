generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id                 String   @id
  title              String
  domain             String
  institution        String?
  role               String?
  inputText          String
  expectedOutputType String
  createdAt          DateTime @default(now())
}

model Answer {
  id            String   @id
  taskId        String
  model         String
  promptVersion String
  content       String
  createdAt     DateTime @default(now())
}

model JudgeResult {
  id                 String   @id
  taskId             String
  answerId           String
  judgeModel         String
  scoreTotal         Int
  scoresJson         String
  rationale          String
  hallucinationFlags String?
  createdAt          DateTime @default(now())
}

model Preference {
  id               String   @id
  taskId           String
  chosenAnswerId   String
  rejectedAnswerId String
  reason           String?
  createdAt        DateTime @default(now())
}
